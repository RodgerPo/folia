// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One row per signed-up user. clerkId links this record to Clerk's auth system.
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  plants    Plant[]
}

// A plant in a user's collection. Stores care data from Perenual and watering schedule.
// nextWaterDue is never stored — always computed as lastWatered + wateringFrequencyDays in code.
model Plant {
  id                    String             @id @default(cuid())
  userId                String
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  scientificName        String?
  wateringFrequencyDays Int                @default(7)
  lastWatered           DateTime?
  imageUrl              String?
  careSummary           String?
  light                 String?
  soil                  String?
  humidity              String?
  perenualId            Int?
  createdAt             DateTime           @default(now())
  healthLogs            HealthLog[]
  wateringReminders     WateringReminder[]
}

// An observation the user logs about a plant. aiAnalysis is filled in after Claude processes it.
model HealthLog {
  id         String   @id @default(cuid())
  plantId    String
  plant      Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  note       String
  photoUrl   String?
  aiAnalysis String?
  createdAt  DateTime @default(now())
}

// Tracks a watering reminder email. token is embedded in the confirmation link.
// confirmedAt is set when the user clicks the link — which also updates Plant.lastWatered.
model WateringReminder {
  id           String    @id @default(cuid())
  plantId      String
  plant        Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)
  token        String    @unique @default(cuid())
  scheduledFor DateTime
  sentAt       DateTime?
  confirmedAt  DateTime?
  createdAt    DateTime  @default(now())
}
